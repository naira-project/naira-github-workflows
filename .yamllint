---
extends: default

rules:
  line-length:
    max: 130
    allow-non-breakable-words: true

  truthy:
    allowed-values: ["true", "false"]
    # check-keys: false allows unquoted 'on:' in GitHub Actions triggers
    check-keys: false

  # GitHub Actions workflow files do not use YAML document markers
  document-start: disable
